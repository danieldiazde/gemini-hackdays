{
  "name": "gemini-hackdays",
  "version": "0.1.0",
  "private": true,
  "description": "TecCoach — Gemini-powered academic coach for Tec de Monterrey students.",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "build:frontend": "pnpm --filter frontend build",
    "lint:frontend": "pnpm --filter frontend lint",
    "typecheck:frontend": "pnpm --filter frontend typecheck",
    "check:frontend": "pnpm lint:frontend && pnpm typecheck:frontend",
    "check": "pnpm check:frontend"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.6"
}
