# Copy this file to `.env.local` for local Next.js development.
# `.env.local` is git-ignored. NEVER commit real keys.

# --- Supabase ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini ------------------------------------------------------------
# Server-side only. Do not expose this through any NEXT_PUBLIC_* variable.
GEMINI_API_KEY=

# --- Google OAuth / Calendar ------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional comma-separated allowlist for real Google-backed accounts in production.
# Leave empty for local development; set in Vercel before sharing a public link.
ALLOWED_USER_EMAILS=

# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "1" to run the UI with fixture data only — no Supabase, Google or
# Gemini calls. Useful for local UI work without credentials.
NEXT_PUBLIC_DEMO_MODE=
