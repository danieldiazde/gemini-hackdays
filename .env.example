# =====================================================================
# Copy this file to `.env` (root) for shared values, and to
# `apps/frontend/.env.local` for any NEXT_PUBLIC_* values you override.
# `.env` and `.env.local` are git-ignored. NEVER commit real keys.
# =====================================================================

# --- Backend (apps/backend) -------------------------------------------
# Required for real Gemini calls. If unset, the backend runs in MOCK
# MODE and returns a clearly-labeled local sample response.
GEMINI_API_KEY=

# Comma-separated list of allowed origins for CORS. Defaults to the
# Next.js dev server below.
FRONTEND_URL=http://localhost:3000

# --- Frontend (apps/frontend) -----------------------------------------
# Public URL of the backend. Anything prefixed with NEXT_PUBLIC_ is
# bundled into the browser, so NEVER put secrets here.
NEXT_PUBLIC_API_URL=http://localhost:8000
