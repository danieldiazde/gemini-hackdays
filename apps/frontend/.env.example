# Public values are exposed to the browser. Never put server secrets here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side values for Next.js API routes.
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional comma-separated allowlist for real Google-backed accounts in production.
# Leave empty for local development; set in Vercel before sharing a public link.
ALLOWED_USER_EMAILS=
